{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Logging": {
        "Url": "http://localhost:5000"
      }
    }
  },
  "AllowedHosts": "*",
  "HealthMonitoring": {
    "ScheduledRestartIntervalHours": 6,
    "UnhealthyRestartDelayMinutes": 5,
    "MaxTimeWithoutOperationMinutes": 30,
    "MaxExceptionsPerMinute": 10,
    "MaxConnectionFailuresPerHour": 50,
    "HealthCheckIntervalSeconds": 30,
    "RestartCheckIntervalMinutes": 1
  }
}
