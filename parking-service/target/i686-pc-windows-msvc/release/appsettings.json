{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Logging": {
        "Url": "http://localhost:5000"
      }
    }
  },
  "AllowedHosts": "*",
  "CameraRestart": {
    "IntervalMinutes": 30
  },
  "ServiceRestart": {
    "IntervalMinutes": 60
  },
  "BlockedCameraIPs": {
    "Enabled": true,
    "IPs": ["192.168.0.11", "192.168.0.12", "192.168.0.13"]
  },
  "DuplicateDetection": {
    "Enabled": true,
    "TimeWindowSeconds": 8,
    "FuzzyMatchEnabled": true,
    "MaxCharacterDifference": 1
  }
}
