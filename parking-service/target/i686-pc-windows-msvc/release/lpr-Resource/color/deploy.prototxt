layer {
  name: "drop"
  type: "Dropout"
  bottom: "conv3_1/sep"
  top: "conv3_1/sep"
  dropout_param {
    dropout_ratio: 0.5
  }
}

layer {
  name: "fc"
  type: "InnerProduct"
  bottom: "conv3_1/sep"
  top: "fc"
  inner_product_param {
    num_output: 13
  }
}
layer {
  name: "prob"
  type: "Softmax"
  bottom: "fc"
  top: "prob"
}
